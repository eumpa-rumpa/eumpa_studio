# Local development defaults for eumpa_studio.
#
# Copy this file to .env when you want to override defaults:
#   cp .env.example .env

# App-owned data directory for uploads, copied workflow templates, exports, and cache.
EUMPA_DATA_ROOT=data

# SQLite database used by the API, worker, and Alembic migrations.
EUMPA_DATABASE_URL=sqlite:///data/eumpa.db

# ComfyUI server used for render submission and output previews.
EUMPA_COMFYUI_URL=http://localhost:8188

# Codex CLI binary used by prompt generation.
EUMPA_CODEX_CLI_PATH=codex

# Alignment command placeholder used by the alignment job runner.
EUMPA_ALIGNMENT_COMMAND=align
